@startuml
skinparam classAttributeIconSize 0

package "Serial Port Terminal" {

class SerialPort {
  +port: str
  +baudrate: int
  +parity: str
  +open()
  +close()
  +write(data)
  +read() : bytes
}

class SerialReader {
  +running: bool
  +start()
  +stop()
  +on_data(data)
}

class SerialWriter {
  +send(text)
}

class TerminalUI {
  +selected_port: str
  +baudrate: int
  +connect()
  +disconnect()
  +send_command(text)
  +display(data)
}

class Settings {
  +baudrate
  +parity
  +stop_bits
  +data_bits
  +load()
  +save()
}

class Logger {
  +file_path
  +write(entry)
  +save()
}

class CommandParser {
  +parse(text) : Command
}

artifact File

SerialPort <|-- SerialReader
SerialPort <|-- SerialWriter
TerminalUI --> SerialPort : uses
TerminalUI --> Logger : logs
TerminalUI --> Settings
TerminalUI --> CommandParser
SerialReader --> TerminalUI : on_receive(data)
SerialWriter --> SerialPort : write(data)
Logger --> File : append

}

@enduml

"""
Sequence diagram: send and receive flow
"""

@startuml
title Send and Receive Flow
participant UI as TerminalUI
participant Parser as CommandParser
participant Writer as SerialWriter
participant Port as SerialPort
participant Reader as SerialReader
participant Log as Logger

UI -> Parser: parse(input)
Parser -> Writer: format(command)
UI -> Writer: send(formatted)
Writer -> Port: write(bytes)
Port -> Reader: data_sent
Reader -> UI: on_data(bytes)
UI -> Log: write(timestamped)
@enduml
